# --- Model provider credentials (set the one matching your SHIPPIE_MODEL) ---
# anthropic/<model>     e.g. anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=
# openai/<model>        e.g. openai/gpt-5.5
OPENAI_API_KEY=
# openrouter/<model>
OPENROUTER_API_KEY=

# Cloudflare Workers AI: model 'cloudflare-workers-ai/@cf/meta/llama-3.3-70b-instruct-fp8-fast'
# CLOUDFLARE_API_KEY accepts a Cloudflare API token (or a `wrangler login` OAuth token) with AI access.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=
# Only for model 'cloudflare-ai-gateway/<model>':
# CLOUDFLARE_GATEWAY_ID=

# --- Shippie config (optional; defaults shown) ---
# SHIPPIE_MODEL=anthropic/claude-sonnet-4-6
# SHIPPIE_REVIEW_LANGUAGE=English
# SHIPPIE_THINKING_LEVEL=medium
# SHIPPIE_TELEMETRY=true   # set to false to opt out of anonymous usage telemetry

# --- Shippie QA (shippie qa; see docs/ambient-qa.md) ---
# SHIPPIE_QA_MODEL=anthropic/claude-opus-4-8
# SHIPPIE_QA_TARGET=http://localhost:5173   # URL/path under test (E2E_BASE_URL)
# SHIPPIE_QA_SCOPE=login, checkout           # flows/areas to prioritize
# SHIPPIE_QA_THINKING_LEVEL=high
# CHROME_BIN=/usr/bin/chromium               # the Chrome/Chromium the agent drives over CDP

# --- GitHub (only when reviewing a PR with platform=github) ---
# GITHUB_TOKEN=

# --- Live "@shippie" channel (webhook server mode only; see docs/tag-shippie.md) ---
# GITHUB_WEBHOOK_SECRET=
